<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="20260218-05-create-magazine-issues-table" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="magazines"/>
            </not>
        </preConditions>
        <createTable tableName="magazines">
            <column name="id" type="integer" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_magazines"/>
            </column>
            <column name="issue" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="publication_id" type="integer">
                <constraints referencedTableName="publications"
                             referencedColumnNames="id"
                             foreignKeyName="fk_magazines_publications"
                             deleteCascade="true"/>
            </column>
            <column name="created_at" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="magazines"
                     indexName="ux_magazines_issue_publication"
                     unique="true">
            <column name="issue"/>
            <column name="publication_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
